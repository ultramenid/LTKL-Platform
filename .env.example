# ==========================================
# LTKL Platform — Web App Environment
# ==========================================
# ⚠️  NOTE: All VITE_ variables are exposed to the browser
# Do NOT put secrets here — only public configuration

# Copy this file to .env and fill in the values
# cp .env.example .env

# --- API URL ---
# Local development:
VITE_API_BASE=http://localhost:3001
# Production:
# VITE_API_BASE=https://api.ltkl.id

# --- App ---
VITE_APP_NAME=LTKL Data Platform

# --- Tile Server ---
VITE_TILE_SERVER=https://gee.simontini.id/gee
